## Фаза 5 — Drag-and-Drop (interact.js)
**Цель:** перетаскивание кнопок в Custom Shelf

```bash
npm install interactjs
```

```js
import interact from 'interactjs';

// Кнопки sidebar можно тащить в полку
interact('.gui-tool-btn').draggable({
  onend(event) {
    const shelf = document.querySelector('custom-shelf');
    const cmdId = event.target.dataset.cmd;
    shelf.addItem({ id: cmdId, label: event.target.textContent });
  }
});

// Кнопки в полке можно менять местами
interact('.shelf button').draggable({
  onmove: dragMoveListener  // стандартный пример из docs
});
```

---

## Фаза 6 — Floating UI (всплывающие панели)
**Цель:** контекстные попапы точно под курсором

```bash
npm install @floating-ui/dom
```

```js
import { computePosition, flip, shift, offset } from '@floating-ui/dom';

function showPopup(referenceEl, popupEl) {
  computePosition(referenceEl, popupEl, {
    placement: 'bottom-start',
    middleware: [offset(8), flip(), shift({ padding: 8 })],
  }).then(({ x, y }) => {
    popupEl.style.left = x + 'px';
    popupEl.style.top  = y + 'px';
    popupEl.style.display = 'block';
  });
}

// Использование: быстрая панель слайдеров под курсором
canvas.addEventListener('keydown', e => {
  if (e.code === 'Space') {
    showPopup(cursorAnchor, quickPanel);
  }
});
```

