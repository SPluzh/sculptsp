## Фаза 3 — Статичный UI (Topbar + Sidebars)
**Цель:** заменить yagui на нативный HTML/CSS

### Структура
```html
<div id="ui-root">          <!-- pointer-events: none -->
  <header id="topbar"></header>
  <aside id="sidebar-left"></aside>
  <aside id="sidebar-right">
    <nav class="tabs">
      <button data-tab="render">Render</button>
      <button data-tab="topology">Topology</button>
      <button data-tab="scene">Scene</button>
    </nav>
    <div class="tab-content" id="tab-render">...</div>
    <div class="tab-content" id="tab-topology">...</div>
  </aside>
</div>
<canvas id="viewport"></canvas>
```

### CSS-токены
```css
:root {
  --bg:        #0d0d0f;
  --panel:     #161618;
  --border:    #2a2a2e;
  --accent:    #00c896;
  --text:      #e0e0e0;
  --text-dim:  #888;
}
```

### Замена GuiModules
Каждый `GuiXxx.js` переписывается как класс который:
- Создаёт свои HTML-элементы (`createElement`)
- Вешает слушатели на `input`, `button`
- Вызывает те же `this._main.*` методы что и раньше

```js
// Пример GuiSculpting.js новый
export class GuiSculpting {
  init(container, main) {
    container.innerHTML = `
      <label>Radius
        <input type="range" id="sl-radius" min="1" max="200" value="50">
      </label>`;
    document.getElementById('sl-radius').oninput = e =>
      main.getSculptManager().setRadius(+e.target.value);
  }
}
```

**Убрать зависимость:** `npm uninstall yagui`

---

## Фаза 4 — Динамичный UI (Lit Web Components)
**Цель:** Pie Menu + Custom Shelf

```bash
npm install lit
```

### 4A — Pie Menu
```js
// src/gui/components/PieMenu.js
import { LitElement, html, css } from 'lit';

export class PieMenu extends LitElement {
  static properties = { items: {}, visible: {}, x: {}, y: {} };

  posFor(i) {
    const angle = (i / this.items.length) * Math.PI * 2 - Math.PI / 2;
    const R = 90;
    return `left:${R + R * Math.cos(angle)}px; top:${R + R * Math.sin(angle)}px`;
  }

  render() {
    if (!this.visible) return html``;
    return html`
      <div class="ring">
        ${this.items.map((item, i) => html`
          <button style=${this.posFor(i)} @click=${() => { item.action(); this.visible = false; }}>
            ${item.icon ? html`<img src=${item.icon}>` : item.label}
          </button>
        `)}
      </div>`;
  }
}
customElements.define('pie-menu', PieMenu);
```

Открывать по правой кнопке мыши на canvas или по клавише (настраивается).

### 4B — Custom Shelf
```js
// src/gui/components/CustomShelf.js
import { LitElement, html } from 'lit';

export class CustomShelf extends LitElement {
  // Команды из localStorage
  get items() {
    return JSON.parse(localStorage.getItem('shelf') || '[]');
  }
  addItem(cmd) {
    const items = this.items;
    items.push(cmd);
    localStorage.setItem('shelf', JSON.stringify(items));
    this.requestUpdate();
  }
  render() {
    return html`
      <div class="shelf">
        ${this.items.map(cmd => html`
          <button @click=${() => COMMANDS[cmd.id]?.()}>
            ${cmd.label}
          </button>
        `)}
      </div>`;
  }
}
customElements.define('custom-shelf', CustomShelf);
```

Реестр команд:
```js
// src/gui/commands.js
export const COMMANDS = {
  smooth:       (main) => main.getSculptManager().setTool(Enums.Tools.SMOOTH),
  flatten:      (main) => main.getSculptManager().setTool(Enums.Tools.FLATTEN),
  remesh_4k:    (main) => main.remesh(4000),
  symmetry_x:   (main) => main.toggleSymmetry('x'),
  // ... все инструменты
};
```

Правая кнопка на любом элементе sidebar → контекстное меню → "Добавить в полку".

